# React Native 0.81 pins react@19.1.0, but Expo internals (@expo/devtools) pull
# react-dom@19.2.7 as an OPTIONAL peer that wants react@19.2.7. react-dom is never
# used by this RN app, so the conflict is harmless — but npm 11's strict peer
# resolution errors on it. Relax to legacy (non-strict) resolution so installs
# (local + EAS cloud builds) succeed deterministically.
legacy-peer-deps=true
